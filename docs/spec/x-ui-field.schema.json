{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://praxis.dev/spec/x-ui-field.schema.json",
  "title": "x-ui (Field) — 1.0.0",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^custom\\.": {}
  },
  "properties": {
    "label": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "text", "number", "email", "date", "password", "file", "url", "boolean", "array", "json"
      ]
    },
    "controlType": {
      "type": "string",
      "description": "Use a família inline* como contrato canônico para superfícies compactas embutidas. O starter publica apenas controlTypes com paridade dinâmica suportada no Angular.",
      "x-canonical-control-type-prefixes": [
        "inline"
      ],
      "x-compatibility-control-types": [],
      "enum": [
        "auto",
        "array",
        "async-select",
        "autoComplete",
        "avatar",
        "button",
        "buttonToggle",
        "checkbox",
        "chipInput",
        "chipList",
        "color",
        "colorPicker",
        "cronBuilder",
        "currency",
        "dateInput",
        "date",
        "dateRange",
        "dateTime",
        "dateTimeRange",
        "email",
        "entityLookup",
        "upload",
        "input",
        "inlineSelect",
        "inlineSearchableSelect",
        "inlineAsyncSelect",
        "inlineEntityLookup",
        "inlineAutocomplete",
        "inlineInput",
        "inlineNumber",
        "inlineCurrency",
        "inlineCurrencyRange",
        "inlineMultiSelect",
        "inlineToggle",
        "inlineRange",
        "inlineDate",
        "inlineDateRange",
        "inlineTime",
        "inlineTimeRange",
        "inlineTreeSelect",
        "inlineRating",
        "inlineDistanceRadius",
        "inlinePipelineStatus",
        "inlineScorePriority",
        "inlineRelativePeriod",
        "inlineSentiment",
        "inlineColorLabel",
        "multiSelect",
        "multiSelectTree",
        "selectionList",
        "numericTextBox",
        "password",
        "phone",
        "cpfCnpjInput",
        "radio",
        "rangeSlider",
        "priceRange",
        "rating",
        "search",
        "searchable-select",
        "select",
        "slider",
        "textarea",
        "time",
        "timePicker",
        "toggle",
        "treeView",
        "transferList",
        "treeSelect",
        "timeRange",
        "month",
        "week",
        "year",
        "dateTimeLocal",
        "url"
      ]
    },
    "group": { "type": "string" },
    "order": { "type": "integer" },
    "width": { "oneOf": [ { "type": "number" }, { "type": "string" } ] },
    "isFlex": { "type": "boolean" },
    "displayOrientation": { "type": "string" },

    "placeholder": { "type": "string" },
    "defaultValue": {},

    "disabled": { "type": "boolean" },
    "readOnly": { "type": "boolean" },
    "multiple": { "type": "boolean" },
    "editable": { "type": "boolean" },
    "validationMode": { "type": "string" },
    "unique": { "type": "boolean" },
    "mask": { "type": "string" },
    "sortable": { "type": "boolean" },
    "filterable": { "type": "boolean" },

    "hidden": { "type": "boolean" },
    "tableHidden": { "type": "boolean" },
    "formHidden": { "type": "boolean" },

    "conditionalDisplay": { "oneOf": [ { "type": "boolean" }, { "type": "string" } ] },
    "dependentField": { "type": "string" },
    "resetOnDependentChange": { "type": "boolean" },

    "inlineEditing": { "type": "boolean" },
    "transformValueFunction": { "type": "string" },
    "debounceTime": { "type": "number", "minimum": 0 },
    "helpText": { "type": "string" },
    "hint": { "type": "string" },
    "tooltipOnHover": { "type": ["string", "boolean"] },

    "icon": { "type": "string" },
    "iconPosition": { "type": "string" },
    "iconSize": { "oneOf": [ { "type": "number" }, { "type": "string" } ] },
    "iconColor": { "type": "string" },
    "iconClass": { "type": "string" },
    "iconStyle": { "type": "string" },
    "iconFontSize": { "oneOf": [ { "type": "number" }, { "type": "string" } ] },

    "endpoint": {
      "type": "string",
      "description": "Backend path for remote options. The Angular runtime normalizes this field to resourcePath."
    },
    "valueField": {
      "type": "string",
      "description": "Option value field name published by the backend. The Angular runtime normalizes this field to optionValueKey."
    },
    "displayField": {
      "type": "string",
      "description": "Option label field name published by the backend. The Angular runtime normalizes this field to optionLabelKey."
    },
    "optionSource": {
      "$ref": "#/definitions/optionSource",
      "description": "Canonical contract for derived option sources."
    },
    "emptyOptionText": { "type": "string" },
    "options": {
      "type": "array",
      "items": { "$ref": "#/definitions/optionItem" }
    },
    "optionGroups": {
      "type": "array",
      "items": { "$ref": "#/definitions/optionItem" }
    },
    "disabledOptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "filter": {
      "oneOf": [ { "type": "string" }, { "type": "object" } ],
      "description": "Additional backend criteria for remote options. The Angular runtime normalizes this field to filterCriteria."
    },
    "filterOptions": { "type": "array" },

    "array": {
      "$ref": "#/definitions/arrayConfig",
      "description": "Canonical editable collection contract for array fields."
    },

    "numericFormat": {
      "type": "string",
      "enum": [
        "integer", "decimal", "currency", "scientific", "time", "date", "date-time", "duration", "number", "fraction", "percent"
      ]
    },
    "valuePresentation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "string", "number", "currency", "percentage", "date", "datetime", "time", "boolean"
          ]
        },
        "style": {
          "type": "string",
          "enum": ["default", "short", "medium", "long", "full", "compact"]
        },
        "format": { "type": "string" },
        "currency": { "type": "object", "additionalProperties": true },
        "number": { "type": "object", "additionalProperties": true }
      },
      "required": ["type"]
    },
    "numericStep": { "oneOf": [ {"type": "number"}, {"type": "string"} ] },
    "numericMin": { "oneOf": [ {"type": "number"}, {"type": "string"} ] },
    "numericMax": { "oneOf": [ {"type": "number"}, {"type": "string"} ] },
    "numericMaxLength": { "type": "integer", "minimum": 0 },

    "required": { "type": "boolean" },
    "requiredMessage": { "type": "string" },
    "minLength": { "type": "integer", "minimum": 0 },
    "minLengthMessage": { "type": "string" },
    "maxLength": { "type": "integer", "minimum": 0 },
    "maxLengthMessage": { "type": "string" },
    "min": { "oneOf": [ {"type": "number"}, {"type": "string"} ] },
    "max": { "oneOf": [ {"type": "number"}, {"type": "string"} ] },
    "minMessage": { "type": "string" },
    "maxMessage": { "type": "string" },
    "range": {
      "oneOf": [
        { "type": "array", "items": { "type": ["number", "string"] }, "minItems": 2 },
        { "type": "object", "properties": { "min": {}, "max": {} }, "additionalProperties": true }
      ]
    },
    "rangeMessage": { "type": "string" },
    "pattern": { "type": "string" },
    "patternMessage": { "type": "string" },
    "regex": { "type": "string" },
    "regexMessage": { "type": "string" },
    "email": { "type": "boolean" },
    "emailMessage": { "type": "string" },
    "url": { "type": "boolean" },
    "urlMessage": { "type": "string" },
    "matchField": { "type": "string" },
    "matchFieldMessage": { "type": "string" },
    "uniqueMessage": { "type": "string" },
    "uniqueValidator": { "type": "string" },
    "conditionalValidation": { "type": "string" },
    "requiredChecked": { "type": "boolean" },
    "allowedFileTypes": { "type": ["array", "string"] },
    "fileTypeMessage": { "type": "string" },
    "maxFileSize": { "type": "number", "minimum": 0 },
    "customValidator": { "type": "string" },
    "asyncValidator": { "type": "string" },
    "minWords": { "type": "integer", "minimum": 0 },
    "validationTrigger": { "oneOf": [ { "type": "string" }, { "type": "array", "items": { "type": "string" } } ] },
    "validationTriggers": { "type": "array", "items": { "type": "string" } },
    "validationDebounce": { "type": "number", "minimum": 0 },
    "showInlineErrors": { "type": "boolean" },
    "errorPosition": { "type": "string" },

    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "minLength": { "type": "integer", "minimum": 0 },
        "maxLength": { "type": "integer", "minimum": 0 },
        "min": { "oneOf": [ {"type": "number"}, {"type": "string"} ] },
        "max": { "oneOf": [ {"type": "number"}, {"type": "string"} ] },
        "pattern": { "type": "string" },
        "patternMessage": { "type": "string" },
        "rangeMessage": { "type": "string" }
      }
    }
  },
  "definitions": {
    "optionItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": {},
        "label": { "type": "string" },
        "disabled": { "type": "boolean" },
        "group": { "type": "string" }
      },
      "required": ["value", "label"]
    },
    "optionSource": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "RESOURCE_ENTITY",
            "DISTINCT_DIMENSION",
            "CATEGORICAL_BUCKET",
            "LIGHT_LOOKUP",
            "STATIC_CANONICAL"
          ]
        },
        "resourcePath": {
          "type": "string",
          "minLength": 1,
          "description": "Backend resource path that owns the option-source endpoints. It can differ from the schema consumer resource when a form field looks up entities from another resource."
        },
        "filterField": {
          "type": "string",
          "minLength": 1
        },
        "propertyPath": {
          "type": "string",
          "minLength": 1
        },
        "labelPropertyPath": {
          "type": "string",
          "minLength": 1
        },
        "valuePropertyPath": {
          "type": "string",
          "minLength": 1
        },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "pattern": "\\S" },
          "uniqueItems": true
        },
        "entityKey": {
          "type": "string",
          "minLength": 1
        },
        "codePropertyPath": {
          "type": "string",
          "minLength": 1
        },
        "descriptionPropertyPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "statusPropertyPath": {
          "type": "string",
          "minLength": 1
        },
        "disabledPropertyPath": {
          "type": "string",
          "minLength": 1
        },
        "disabledReasonPropertyPath": {
          "type": "string",
          "minLength": 1
        },
        "searchPropertyPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "dependencyFilterMap": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        },
        "selectionPolicy": {
          "$ref": "#/definitions/lookupSelectionPolicy"
        },
        "capabilities": {
          "$ref": "#/definitions/lookupCapabilities"
        },
        "detail": {
          "$ref": "#/definitions/lookupDetail"
        },
        "excludeSelfField": { "type": "boolean" },
        "searchMode": {
          "type": "string",
          "enum": ["none", "starts-with", "contains", "exact"]
        },
        "pageSize": {
          "type": "integer",
          "minimum": 1
        },
        "includeIds": { "type": "boolean" },
        "cachePolicy": {
          "type": "string",
          "enum": ["none", "request-scope", "session-scope", "etag-aware"]
        }
      },
      "required": ["key", "type", "resourcePath"]
    },
    "lookupSelectionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selectablePropertyPath": { "type": "string", "minLength": 1 },
        "statusPropertyPath": { "type": "string", "minLength": 1 },
        "allowedStatuses": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "blockedStatuses": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "allowRetainInvalidExistingValue": { "type": "boolean" },
        "disabledReasonTemplate": { "type": "string" },
        "validationMessageTemplate": { "type": "string" }
      }
    },
    "lookupCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filter": { "type": "boolean" },
        "byIds": { "type": "boolean" },
        "detail": { "type": "boolean" },
        "create": { "type": "boolean" },
        "edit": { "type": "boolean" },
        "navigateToDetail": { "type": "boolean" },
        "multiSelect": { "type": "boolean" },
        "recent": { "type": "boolean" },
        "favorites": { "type": "boolean" },
        "auditSnapshot": { "type": "boolean" }
      }
    },
    "lookupDetail": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hrefTemplate": { "type": "string", "minLength": 1 },
        "routeTemplate": { "type": "string", "minLength": 1 },
        "openDetailMode": {
          "type": "string",
          "enum": ["samePage", "newTab", "drawer", "modal"]
        }
      }
    },
    "arrayConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "itemType": {
          "type": "string",
          "enum": ["object"]
        },
        "mode": {
          "type": "string",
          "enum": ["cards"]
        },
        "itemSchemaRef": {
          "type": "string",
          "minLength": 1
        },
        "itemSchema": {
          "$ref": "#/definitions/arrayItemSchema",
          "description": "Inline item schema published by /schemas/filtered when itemSchemaRef points to an OpenAPI component."
        },
        "itemIdentityField": {
          "type": "string",
          "minLength": 1
        },
        "minItems": {
          "type": "integer",
          "minimum": 0
        },
        "maxItems": {
          "type": "integer",
          "minimum": 0
        },
        "addLabel": {
          "type": "string"
        },
        "emptyState": {
          "type": "string"
        },
        "itemTitleTemplate": {
          "type": "string"
        },
        "deleteMode": {
          "type": "string",
          "enum": ["removeFromPayload"]
        },
        "operations": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "add": { "type": "boolean" },
            "edit": { "type": "boolean" },
            "remove": { "type": "boolean" }
          }
        },
        "collectionValidation": {
          "$ref": "#/definitions/collectionValidation"
        }
      }
    },
    "arrayItemSchema": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["object"]
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string", "minLength": 1 }
            },
            "required": ["name"]
          }
        }
      },
      "required": ["fields"]
    },
    "collectionValidation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "uniqueBy": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "atLeastOne": {
          "$ref": "#/definitions/collectionFieldCondition"
        },
        "exactlyOne": {
          "$ref": "#/definitions/collectionFieldCondition"
        },
        "sumEquals": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "field": { "type": "string", "minLength": 1 },
            "targetField": { "type": "string", "minLength": 1 },
            "message": { "type": "string" }
          },
          "required": ["field", "targetField"]
        }
      }
    },
    "collectionFieldCondition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "value": {},
        "message": { "type": "string" }
      },
      "required": ["field"]
    }
  }
}
