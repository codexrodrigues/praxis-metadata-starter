{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://praxis.dev/spec/x-ui-field.schema.json",
  "title": "x-ui (Field) — 1.0.0",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^custom\\.": {}
  },
  "properties": {
    "label": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "text", "number", "email", "date", "password", "file", "url", "boolean", "array", "json"
      ]
    },
    "controlType": {
      "type": "string",
      "description": "Use a família inline* como contrato canônico para superfícies compactas embutidas. O starter publica apenas controlTypes com paridade dinâmica suportada no Angular.",
      "x-canonical-control-type-prefixes": [
        "inline"
      ],
      "x-compatibility-control-types": [],
      "enum": [
        "auto",
        "array",
        "async-select",
        "autoComplete",
        "avatar",
        "button",
        "buttonToggle",
        "checkbox",
        "chipInput",
        "chipList",
        "color",
        "colorPicker",
        "cronBuilder",
        "currency",
        "dateInput",
        "date",
        "dateRange",
        "dateTime",
        "dateTimeRange",
        "email",
        "entityLookup",
        "upload",
        "input",
        "inlineSelect",
        "inlineSearchableSelect",
        "inlineAsyncSelect",
        "inlineEntityLookup",
        "inlineAutocomplete",
        "inlineInput",
        "inlineNumber",
        "inlineCurrency",
        "inlineCurrencyRange",
        "inlineMultiSelect",
        "inlineToggle",
        "inlineRange",
        "inlineDate",
        "inlineDateRange",
        "inlineTime",
        "inlineTimeRange",
        "inlineTreeSelect",
        "inlineRating",
        "inlineDistanceRadius",
        "inlinePipelineStatus",
        "inlineScorePriority",
        "inlineRelativePeriod",
        "inlineSentiment",
        "inlineColorLabel",
        "multiSelect",
        "multiSelectTree",
        "selectionList",
        "numericTextBox",
        "password",
        "phone",
        "cpfCnpjInput",
        "radio",
        "rangeSlider",
        "priceRange",
        "rating",
        "search",
        "searchable-select",
        "select",
        "slider",
        "textarea",
        "time",
        "timePicker",
        "toggle",
        "treeView",
        "transferList",
        "treeSelect",
        "timeRange",
        "month",
        "week",
        "year",
        "dateTimeLocal",
        "url"
      ]
    },
    "presentationPreset": {
      "type": "string",
      "description": "Presentation-only authoring accelerator. It may set repetitive UI metadata, but it must not replace explicit domain documentation in OpenAPI Schema descriptions.",
      "enum": [
        "none",
        "enterprise-id",
        "enterprise-code",
        "enterprise-name",
        "enterprise-status",
        "date-range",
        "monetary-amount",
        "boolean-flag",
        "legal-document-reference",
        "tenant-label",
        "audit-timestamp"
      ]
    },
    "group": { "type": "string" },
    "order": { "type": "integer" },
    "width": { "oneOf": [ { "type": "number" }, { "type": "string" } ] },
    "isFlex": { "type": "boolean" },
    "displayOrientation": { "type": "string" },

    "placeholder": { "type": "string" },
    "defaultValue": {},

    "disabled": { "type": "boolean" },
    "readOnly": { "type": "boolean" },
    "multiple": { "type": "boolean" },
    "editable": { "type": "boolean" },
    "validationMode": { "type": "string" },
    "unique": { "type": "boolean" },
    "mask": { "type": "string" },
    "sortable": { "type": "boolean" },
    "filterable": { "type": "boolean" },

    "hidden": { "type": "boolean" },
    "tableHidden": { "type": "boolean" },
    "formHidden": { "type": "boolean" },
    "fieldAccess": {
      "$ref": "#/definitions/fieldAccess",
      "description": "Declarative field-level access policy. It guides runtime rendering and backend validation, but does not replace server-side authorization."
    },

    "conditionalDisplay": {
      "$ref": "#/definitions/jsonLogicExpression",
      "description": "Canonical Json Logic condition validated against the Praxis runtime operator matrix, including operator arity and basic literal argument shape. Textual DSLs and JSON Schema conditionals are rejected by the backend."
    },
    "dependentField": { "type": "string" },
    "resetOnDependentChange": { "type": "boolean" },

    "inlineEditing": { "type": "boolean" },
    "transformValueFunction": { "type": "string" },
    "debounceTime": { "type": "number", "minimum": 0 },
    "helpText": { "type": "string" },
    "hint": { "type": "string" },
    "tooltipOnHover": { "type": ["string", "boolean"] },

    "icon": { "type": "string" },
    "iconPosition": { "type": "string" },
    "iconSize": { "oneOf": [ { "type": "number" }, { "type": "string" } ] },
    "iconColor": { "type": "string" },
    "iconClass": { "type": "string" },
    "iconStyle": { "type": "string" },
    "iconFontSize": { "oneOf": [ { "type": "number" }, { "type": "string" } ] },

    "endpoint": {
      "type": "string",
      "description": "Backend path for remote options. The Angular runtime normalizes this field to resourcePath."
    },
    "valueField": {
      "type": "string",
      "description": "Option value field name published by the backend. The Angular runtime normalizes this field to optionValueKey."
    },
    "displayField": {
      "type": "string",
      "description": "Option label field name published by the backend. The Angular runtime normalizes this field to optionLabelKey."
    },
    "optionSource": {
      "$ref": "#/definitions/optionSource",
      "description": "Canonical contract for derived option sources."
    },
    "emptyOptionText": { "type": "string" },
    "options": {
      "type": "array",
      "items": { "$ref": "#/definitions/optionItem" }
    },
    "shortcuts": {
      "type": "array",
      "items": { "$ref": "#/definitions/dateRangeShortcut" },
      "description": "Ordered date-range shortcut catalog for dateRange and inlineDateRange. Backend/domain services publish built-in ids or static resolved business periods. JSON metadata must not contain calculateRange, callbacks, scripts or frontend-executed business rules."
    },
    "inlineQuickPresets": {
      "oneOf": [
        { "type": "boolean" },
        { "$ref": "#/definitions/inlineQuickPresets" }
      ],
      "description": "Inline date-range shortcut composition. position uses logical start/end and may fall back to footer in narrow or touch layouts."
    },
    "inlineOverlay": {
      "$ref": "#/definitions/inlineOverlay",
      "description": "Inline date-range overlay commit/action metadata. It controls UI materialization only; submitted filters still use startDate and endDate."
    },
    "optionGroups": {
      "type": "array",
      "items": { "$ref": "#/definitions/optionItem" }
    },
    "disabledOptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "filter": {
      "oneOf": [ { "type": "string" }, { "type": "object" } ],
      "description": "Additional backend criteria for remote options. The Angular runtime normalizes this field to filterCriteria."
    },
    "filterOptions": { "type": "array" },

    "array": {
      "$ref": "#/definitions/arrayConfig",
      "description": "Canonical editable collection contract for array fields."
    },

    "numericFormat": {
      "type": "string",
      "enum": [
        "integer", "decimal", "currency", "scientific", "time", "date", "date-time", "duration", "number", "fraction", "percent"
      ]
    },
    "valuePresentation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "string", "number", "currency", "percentage", "date", "datetime", "time", "boolean"
          ]
        },
        "style": {
          "type": "string",
          "enum": ["default", "short", "medium", "long", "full", "compact"]
        },
        "format": { "type": "string" },
        "currency": { "type": "object", "additionalProperties": true },
        "number": { "type": "object", "additionalProperties": true }
      },
      "required": ["type"]
    },
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "description": "Canonical readonly/list/table-cell visual presentation metadata. It complements valuePresentation and may be materialized by consumers as chips, badges, icon+value or compact visualizations without changing the raw field value used for sort, filter and export.",
      "properties": {
        "presenter": {
          "type": "string",
          "enum": ["text", "badge", "chip", "status", "iconValue", "progress", "rating", "microVisualization"]
        },
        "variant": {
          "type": "string",
          "enum": ["text", "badge", "chip", "status", "iconValue", "progress", "rating", "microVisualization"]
        },
        "tone": {
          "type": "string",
          "enum": ["neutral", "info", "success", "warning", "danger"]
        },
        "icon": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "prefix": { "type": "string" },
        "suffix": { "type": "string" },
        "badge": { "type": "string", "minLength": 1 },
        "tooltip": { "type": "string", "minLength": 1 },
        "appearance": {
          "type": "string",
          "enum": ["plain", "soft", "outlined", "filled"]
        },
        "valuePresentation": { "$ref": "#/properties/valuePresentation" },
        "visualization": { "type": "object", "additionalProperties": true },
        "interactions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "copy": { "type": "boolean" },
            "details": { "type": "boolean" },
            "expand": { "type": "boolean" },
            "link": { "type": "boolean" }
          }
        }
      }
    },
    "numericStep": { "oneOf": [ {"type": "number"}, {"type": "string"} ] },
    "numericMin": { "oneOf": [ {"type": "number"}, {"type": "string"} ] },
    "numericMax": { "oneOf": [ {"type": "number"}, {"type": "string"} ] },
    "numericMaxLength": { "type": "integer", "minimum": 0 },

    "required": { "type": "boolean" },
    "requiredMessage": { "type": "string" },
    "minLength": { "type": "integer", "minimum": 0 },
    "minLengthMessage": { "type": "string" },
    "maxLength": { "type": "integer", "minimum": 0 },
    "maxLengthMessage": { "type": "string" },
    "min": { "oneOf": [ {"type": "number"}, {"type": "string"} ] },
    "max": { "oneOf": [ {"type": "number"}, {"type": "string"} ] },
    "minMessage": { "type": "string" },
    "maxMessage": { "type": "string" },
    "range": {
      "oneOf": [
        { "type": "array", "items": { "type": ["number", "string"] }, "minItems": 2 },
        { "type": "object", "properties": { "min": {}, "max": {} }, "additionalProperties": true }
      ]
    },
    "rangeMessage": { "type": "string" },
    "pattern": { "type": "string" },
    "patternMessage": { "type": "string" },
    "regex": { "type": "string" },
    "regexMessage": { "type": "string" },
    "email": { "type": "boolean" },
    "emailMessage": { "type": "string" },
    "url": { "type": "boolean" },
    "urlMessage": { "type": "string" },
    "matchField": { "type": "string" },
    "matchFieldMessage": { "type": "string" },
    "uniqueMessage": { "type": "string" },
    "uniqueValidator": { "type": "string" },
    "conditionalRequired": {
      "$ref": "#/definitions/jsonLogicExpression",
      "description": "Canonical Json Logic condition validated against the Praxis runtime operator matrix, including operator arity and basic literal argument shape. The same value is also mirrored into validation.conditionalRequired when materialized from @UISchema."
    },
    "conditionalValidation": {
      "type": "array",
      "items": { "$ref": "#/definitions/conditionalValidationRule" },
      "description": "Declarative conditional validation rules. Each condition is a canonical Json Logic object/null validated against the Praxis runtime operator matrix, including operator arity and basic literal argument shape. This is a JSON/config-driven x-ui contract consumed by the Angular runtime; Java DTO annotations can materialize it through structured extraProperties, but they are not the primary authoring surface for complex Json Logic."
    },
    "requiredChecked": { "type": "boolean" },
    "allowedFileTypes": { "type": ["array", "string"] },
    "fileTypeMessage": { "type": "string" },
    "maxFileSize": { "type": "number", "minimum": 0 },
    "customValidator": { "type": "string" },
    "asyncValidator": { "type": "string" },
    "minWords": { "type": "integer", "minimum": 0 },
    "validationTrigger": { "oneOf": [ { "type": "string" }, { "type": "array", "items": { "type": "string" } } ] },
    "validationTriggers": { "type": "array", "items": { "type": "string" } },
    "validationDebounce": { "type": "number", "minimum": 0 },
    "showInlineErrors": { "type": "boolean" },
    "errorPosition": { "type": "string" },

    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "minLength": { "type": "integer", "minimum": 0 },
        "maxLength": { "type": "integer", "minimum": 0 },
        "min": { "oneOf": [ {"type": "number"}, {"type": "string"} ] },
        "max": { "oneOf": [ {"type": "number"}, {"type": "string"} ] },
        "pattern": { "type": "string" },
        "patternMessage": { "type": "string" },
        "rangeMessage": { "type": "string" },
        "conditionalRequired": { "$ref": "#/definitions/jsonLogicExpression" }
      }
    }
  },
  "definitions": {
    "optionItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": {},
        "label": { "type": "string" },
        "disabled": { "type": "boolean" },
        "group": { "type": "string" }
      },
      "required": ["value", "label"]
    },
    "dateRangeShortcut": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "enum": ["today", "yesterday", "thisWeek", "lastWeek", "thisMonth", "lastMonth", "thisYear", "lastYear"],
          "description": "Built-in shortcut id understood by the Angular runtime. Domain-specific business periods must be published as staticDateRangePreset objects."
        },
        { "$ref": "#/definitions/staticDateRangePreset" }
      ]
    },
    "staticDateRangePreset": {
      "type": "object",
      "additionalProperties": false,
      "description": "Static, serializable, backend-resolved business period. The backend/domain owns fiscal, legal, electoral, holiday and countable-day rules before publication.",
      "properties": {
        "id": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "label": { "type": "string", "minLength": 1 },
        "startDate": { "$ref": "#/definitions/isoDateOnly" },
        "endDate": { "$ref": "#/definitions/isoDateOnly" },
        "timeZone": {
          "type": "string",
          "minLength": 1,
          "description": "IANA timezone used by the domain when resolving the date-only period."
        },
        "icon": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "tone": {
          "type": "string",
          "enum": ["neutral", "info", "success", "warning"],
          "description": "Semantic tone resolved by Praxis/host tokens, never an arbitrary color."
        },
        "effectiveFrom": { "$ref": "#/definitions/isoDateOnly" },
        "effectiveTo": { "$ref": "#/definitions/isoDateOnly" }
      },
      "required": ["id", "label", "startDate", "endDate"]
    },
    "inlineQuickPresets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "maxVisible": { "type": "integer", "minimum": 1 },
        "position": {
          "type": "string",
          "enum": ["auto", "footer", "start", "end"],
          "description": "Logical placement; start/end honor RTL and auto may fall back to footer."
        }
      }
    },
    "inlineOverlay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "applyMode": {
          "type": "string",
          "enum": ["auto", "explicit"]
        },
        "actions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "apply": { "$ref": "#/definitions/inlineOverlayAction" },
            "cancel": { "$ref": "#/definitions/inlineOverlayAction" }
          }
        }
      }
    },
    "inlineOverlayAction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "ariaLabel": { "type": "string", "minLength": 1 },
        "appearance": {
          "type": "string",
          "enum": ["text", "outlined", "filled", "elevated"]
        },
        "colorRole": {
          "type": "string",
          "enum": ["primary", "neutral", "warning", "danger"]
        }
      }
    },
    "isoDateOnly": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO date-only value (YYYY-MM-DD). Business-day, legal, fiscal and electoral calculations must be resolved before publishing metadata."
    },
    "fieldAccess": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "visibleForAuthorities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "pattern": "\\S" },
          "minItems": 1,
          "uniqueItems": true
        },
        "editableForAuthorities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "pattern": "\\S" },
          "minItems": 1,
          "uniqueItems": true
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "anyOf": [
        { "required": ["visibleForAuthorities"] },
        { "required": ["editableForAuthorities"] }
      ]
    },
    "jsonLogicExpression": {
      "type": ["object", "null"],
      "description": "Canonical Json Logic object or null. Textual DSLs and JSON Schema conditionals are not part of this x-ui contract."
    },
    "conditionalValidationRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "condition": { "$ref": "#/definitions/jsonLogicExpression" },
        "validators": {
          "type": "object",
          "additionalProperties": true,
          "minProperties": 1,
          "description": "Validator options applied when condition evaluates to true. The Angular runtime normalizes this object with the same validator parser used for field-level validation."
        }
      },
      "required": ["condition", "validators"]
    },
    "optionSource": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "RESOURCE_ENTITY",
            "DISTINCT_DIMENSION",
            "CATEGORICAL_BUCKET",
            "LIGHT_LOOKUP",
            "STATIC_CANONICAL"
          ]
        },
        "resourcePath": {
          "type": "string",
          "minLength": 1,
          "description": "Backend resource path that owns the option-source endpoints. It can differ from the schema consumer resource when a form field looks up entities from another resource."
        },
        "filterField": {
          "type": "string",
          "minLength": 1
        },
        "propertyPath": {
          "type": "string",
          "minLength": 1
        },
        "labelPropertyPath": {
          "type": "string",
          "minLength": 1
        },
        "valuePropertyPath": {
          "type": "string",
          "minLength": 1
        },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "pattern": "\\S" },
          "uniqueItems": true
        },
        "entityKey": {
          "type": "string",
          "minLength": 1
        },
        "codePropertyPath": {
          "type": "string",
          "minLength": 1
        },
        "descriptionPropertyPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "statusPropertyPath": {
          "type": "string",
          "minLength": 1
        },
        "disabledPropertyPath": {
          "type": "string",
          "minLength": 1
        },
        "disabledReasonPropertyPath": {
          "type": "string",
          "minLength": 1
        },
        "searchPropertyPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "dependencyFilterMap": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        },
        "selectionPolicy": {
          "$ref": "#/definitions/lookupSelectionPolicy"
        },
        "capabilities": {
          "$ref": "#/definitions/lookupCapabilities"
        },
        "detail": {
          "$ref": "#/definitions/lookupDetail"
        },
        "create": {
          "$ref": "#/definitions/lookupCreate"
        },
        "display": {
          "$ref": "#/definitions/lookupDisplay"
        },
        "filtering": {
          "$ref": "#/definitions/lookupFiltering"
        },
        "excludeSelfField": { "type": "boolean" },
        "searchMode": {
          "type": "string",
          "enum": ["none", "starts-with", "contains", "exact"]
        },
        "pageSize": {
          "type": "integer",
          "minimum": 1
        },
        "includeIds": { "type": "boolean" },
        "cachePolicy": {
          "type": "string",
          "enum": ["none", "request-scope", "session-scope", "etag-aware"]
        },
        "filterEndpoint": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical endpoint for filtering options from this source."
        },
        "byIdsEndpoint": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical endpoint for selected-value reload by IDs."
        },
        "selectedReloadPolicy": {
          "type": "string",
          "enum": ["required", "supported", "unsupported-with-waiver", "not-applicable"]
        },
        "invalidSortPolicy": {
          "type": "string",
          "enum": ["reject", "ignore", "unsupported"]
        }
      },
      "required": ["key", "type", "resourcePath"]
    },
    "lookupSelectionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selectablePropertyPath": { "type": "string", "minLength": 1 },
        "statusPropertyPath": { "type": "string", "minLength": 1 },
        "allowedStatuses": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "blockedStatuses": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "allowRetainInvalidExistingValue": { "type": "boolean" },
        "disabledReasonTemplate": { "type": "string" },
        "validationMessageTemplate": { "type": "string" }
      }
    },
    "lookupCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filter": { "type": "boolean" },
        "byIds": { "type": "boolean" },
        "detail": { "type": "boolean" },
        "create": { "type": "boolean" },
        "edit": { "type": "boolean" },
        "navigateToDetail": { "type": "boolean" },
        "multiSelect": { "type": "boolean" },
        "recent": { "type": "boolean" },
        "favorites": { "type": "boolean" },
        "auditSnapshot": { "type": "boolean" }
      }
    },
    "lookupDetail": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hrefTemplate": { "type": "string", "minLength": 1 },
        "routeTemplate": { "type": "string", "minLength": 1 },
        "openDetailMode": {
          "type": "string",
          "enum": ["samePage", "newTab", "drawer", "modal", "route", "surface"]
        },
        "kind": {
          "type": "string",
          "enum": ["surface", "route", "href"]
        },
        "surfaceId": { "type": "string", "minLength": 1 },
        "presentation": {
          "type": "string",
          "enum": ["drawer", "modal"]
        },
        "preferredWidget": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "minLength": 1 }
      }
    },
    "lookupCreate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hrefTemplate": { "type": "string", "minLength": 1 },
        "routeTemplate": { "type": "string", "minLength": 1 },
        "openMode": {
          "type": "string",
          "enum": ["samePage", "newTab", "drawer", "modal", "route"]
        }
      }
    },
    "lookupDisplay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preset": {
          "type": "string",
          "enum": ["compact", "rich", "directory", "status", "reference", "hierarchical"]
        },
        "usage": {
          "type": "string",
          "enum": ["form", "filter", "table-cell", "dashboard", "wizard", "review"]
        },
        "density": {
          "type": "string",
          "enum": ["compact", "comfortable", "rich"]
        },
        "selectedLayout": {
          "type": "string",
          "enum": ["card", "inline", "compact", "token"]
        },
        "resultLayout": {
          "type": "string",
          "enum": ["list", "denseList", "table", "card"]
        },
        "primaryPropertyPath": { "type": "string", "minLength": 1 },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/definitions/lookupDisplayField" }
        },
        "secondaryPropertyPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "badgePropertyPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "avatarPropertyPath": { "type": "string", "minLength": 1 },
        "showAvatar": { "type": "boolean" },
        "showCode": { "type": "boolean" },
        "showDescription": { "type": "boolean" },
        "showStatus": { "type": "boolean" },
        "showBadges": { "type": "boolean" },
        "showDisabledReason": { "type": "boolean" },
        "showResultCount": { "type": "boolean" },
        "statusToneMap": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["neutral", "success", "warning", "danger"]
          }
        },
        "badgeKeys": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "detailActionLabel": { "type": "string" },
        "changeActionLabel": { "type": "string" },
        "copyCodeActionLabel": { "type": "string" },
        "copyIdActionLabel": { "type": "string" },
        "createActionLabel": { "type": "string" },
        "clearActionLabel": { "type": "string" },
        "actions": {
          "$ref": "#/definitions/lookupDisplayActions"
        },
        "maxVisibleBadges": { "type": "integer", "minimum": 0 }
      }
    },
    "lookupDisplayActions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "showDetail": { "type": "boolean" },
        "showChange": { "type": "boolean" },
        "showCopyCode": { "type": "boolean" },
        "showCopyId": { "type": "boolean" },
        "showCreate": { "type": "boolean" },
        "showClear": { "type": "boolean" }
      }
    },
    "lookupDisplayField": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "propertyPath": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "icon": { "type": "string", "minLength": 1 },
        "presentation": {
          "type": "string",
          "enum": ["text", "chip", "badge", "date", "currency", "metric"]
        },
        "tone": {
          "type": "string",
          "enum": ["neutral", "info", "success", "warning", "danger"]
        },
        "format": { "type": "string", "minLength": 1 }
      }
    },
    "lookupFiltering": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "availableFilters": {
          "type": "array",
          "items": { "$ref": "#/definitions/lookupFilterDefinition" }
        },
        "defaultFilters": {
          "type": "object",
          "additionalProperties": true
        },
        "sortOptions": {
          "type": "array",
          "items": { "$ref": "#/definitions/lookupSortOption" }
        },
        "defaultSort": { "type": "string", "minLength": 1 },
        "quickFilterFields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "searchPlaceholder": { "type": "string" }
      }
    },
    "lookupFilterDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["text", "enum", "date", "number", "reference"]
        },
        "operators": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["contains", "startsWith", "equals", "in", "before", "after", "between", "gt", "gte", "lt", "lte"]
          },
          "uniqueItems": true
        },
        "defaultOperator": {
          "type": "string",
          "enum": ["contains", "startsWith", "equals", "in", "before", "after", "between", "gt", "gte", "lt", "lte"]
        },
        "optionsSource": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "hidden": { "type": "boolean" }
      },
      "required": ["field", "type"]
    },
    "lookupSortOption": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "field": { "type": "string", "minLength": 1 },
        "direction": {
          "type": "string",
          "enum": ["asc", "desc"],
          "default": "asc"
        },
        "label": { "type": "string" }
      },
      "required": ["key", "field"]
    },
    "arrayConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "itemType": {
          "type": "string",
          "enum": ["object"]
        },
        "mode": {
          "type": "string",
          "enum": ["cards"]
        },
        "itemSchemaRef": {
          "type": "string",
          "minLength": 1
        },
        "itemSchema": {
          "$ref": "#/definitions/arrayItemSchema",
          "description": "Inline item schema published by /schemas/filtered when itemSchemaRef points to an OpenAPI component."
        },
        "itemIdentityField": {
          "type": "string",
          "minLength": 1
        },
        "minItems": {
          "type": "integer",
          "minimum": 0
        },
        "maxItems": {
          "type": "integer",
          "minimum": 0
        },
        "addLabel": {
          "type": "string"
        },
        "emptyState": {
          "type": "string"
        },
        "itemTitleTemplate": {
          "type": "string"
        },
        "deleteMode": {
          "type": "string",
          "enum": ["removeFromPayload"]
        },
        "operations": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "add": { "type": "boolean" },
            "edit": { "type": "boolean" },
            "remove": { "type": "boolean" }
          }
        },
        "collectionValidation": {
          "$ref": "#/definitions/collectionValidation"
        }
      }
    },
    "arrayItemSchema": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["object"]
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string", "minLength": 1 }
            },
            "required": ["name"]
          }
        }
      },
      "required": ["fields"]
    },
    "collectionValidation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "uniqueBy": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "atLeastOne": {
          "$ref": "#/definitions/collectionFieldCondition"
        },
        "exactlyOne": {
          "$ref": "#/definitions/collectionFieldCondition"
        },
        "sumEquals": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "field": { "type": "string", "minLength": 1 },
            "targetField": { "type": "string", "minLength": 1 },
            "message": { "type": "string" }
          },
          "required": ["field", "targetField"]
        }
      }
    },
    "collectionFieldCondition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "value": {},
        "message": { "type": "string" }
      },
      "required": ["field"]
    }
  }
}
