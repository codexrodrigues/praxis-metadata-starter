{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://praxis.dev/spec/x-ui-operation.schema.json",
  "title": "x-ui (Operation) — 1.0.0",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^custom\\.": {}
  },
  "properties": {
    "displayColumns": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "displayFields": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "filterFields": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "responseSchema": { "type": "string" },
    "relatedEntitiesEndpoints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "operationExamples": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request": { "$ref": "#/$defs/exampleCollection" },
        "response": { "$ref": "#/$defs/exampleCollection" }
      }
    }
  },
  "$defs": {
    "exampleCollection": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "summary": { "type": "string" },
          "description": { "type": "string" },
          "value": {},
          "externalValue": {
            "type": "string",
            "format": "uri"
          }
        },
        "anyOf": [
          { "required": ["value"] },
          { "required": ["externalValue"] }
        ]
      }
    }
  }
}
