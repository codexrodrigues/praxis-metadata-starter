{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://praxis.dev/spec/x-ui-resource.schema.json",
  "title": "x-ui.resource (/schemas/filtered payload) — 1.0.0",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "idField": { "type": "string", "minLength": 1 },
    "idFieldValid": { "type": "boolean" },
    "idFieldMessage": { "type": "string" },
    "readOnly": { "type": "boolean" },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "keyField": { "type": "string", "minLength": 1 },
        "titleField": { "type": "string", "minLength": 1 },
        "metadataFields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "displayLabelField": { "type": "string", "minLength": 1 },
        "valid": { "type": "boolean" },
        "invalidFields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "message": { "type": "string" }
      },
      "required": ["valid"],
      "anyOf": [
        { "required": ["keyField"] },
        { "required": ["titleField"] },
        { "required": ["displayLabelField"] }
      ]
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": { "type": "boolean" },
      "properties": {
        "create": { "type": "boolean" },
        "update": { "type": "boolean" },
        "delete": { "type": "boolean" },
        "options": { "type": "boolean" },
        "byId": { "type": "boolean" },
        "all": { "type": "boolean" },
        "filter": { "type": "boolean" },
        "filterExpression": { "type": "boolean" },
        "cursor": { "type": "boolean" }
      }
    }
  },
  "required": ["idField", "idFieldValid", "readOnly", "capabilities"]
}
